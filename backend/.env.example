# Django Settings
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,edms.local

# Runtime & Port
EDMS_RUNTIME_PORT=8420
EDMS_RUNTIME_HOST=0.0.0.0
EDMS_WAITRESS_HOST=0.0.0.0

# Storage
EDMS_STORAGE_ROOT=./storage

# LAN Security
EDMS_ALLOWED_IP_RANGES=192.168.0.0/16,172.16.0.0/12,10.0.0.0/8
EDMS_TRUSTED_PROXY_IPS=127.0.0.1

# Database - SQLite (default)
EDMS_SQLITE_PATH=./db.sqlite3

# Database - PostgreSQL (optional)
# Uncomment to use PostgreSQL instead of SQLite
# EDMS_DB_ENGINE=postgresql
# POSTGRES_DB=edms_db
# POSTGRES_USER=edms_user
# POSTGRES_PASSWORD=secure_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_SSLMODE=prefer
# Or use DATABASE_URL instead:
# DATABASE_URL=postgresql://user:password@host:5432/edms_db

# OCR
TESSERACT_CMD=/usr/bin/tesseract

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password

# JWT
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRY_HOURS=24
